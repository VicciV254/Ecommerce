generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== USER MODELS ==========

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  password        String
  firstName       String
  lastName        String
  phone           String?
  profileImage    String?
  emailVerified   Boolean       @default(false)
  emailVerifyToken String?      @unique
  emailVerifyExpires DateTime?
  otpCode         String?
  otpExpiresAt    DateTime?
  otpAttempts     Int           @default(0)
  otpLastSentAt   DateTime?
  isDisabled      Boolean       @default(false)
  promotionalEmails Boolean     @default(false)
  addresses       Address[]
  orders          Order[]
  wishlist        Wishlist[]
  cart            Cart?
  passwordReset   PasswordReset?
  reviews         Review[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model SiteSetting {
  key             String        @id
  value           Json
  updatedAt       DateTime      @updatedAt
  createdAt       DateTime      @default(now())
}

model MpesaPayment {
  id              String        @id @default(cuid())
  checkoutRequestId String      @unique
  merchantRequestId String?
  orderNumber     String?
  phone           String
  amount          Float
  status          String        @default("PENDING")
  resultCode      Int?
  resultDesc      String?
  receiptNumber   String?
  rawCallback     Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Address {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  street          String
  city            String
  county          String
  postalCode      String?
  isDefault       Boolean       @default(false)
  orders          Order[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Cart {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id])
  items           CartItem[]
  subtotal        Float         @default(0)
  discount        Float         @default(0)
  total           Float         @default(0)
  couponCode      String?
  updatedAt       DateTime      @updatedAt
}

model CartItem {
  id              String        @id @default(cuid())
  cartId          String
  cart            Cart          @relation(fields: [cartId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int           @default(1)
  price           Float
  createdAt       DateTime      @default(now())
}

model Wishlist {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  createdAt       DateTime      @default(now())
}

model PasswordReset {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id])
  token           String        @unique
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime      @default(now())
}

model Subscription {
  id              String        @id @default(cuid())
  email           String        @unique
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ========== ADMIN MODELS ==========

model Admin {
  id              String        @id @default(cuid())
  email           String        @unique
  username        String        @unique
  password        String
  role            AdminRole     @default(ADMIN)
  lastLogin       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  activityLogs    ActivityLog[]
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

model ActivityLog {
  id              String        @id @default(cuid())
  adminId         String
  admin           Admin         @relation(fields: [adminId], references: [id])
  action          String
  details         String
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())
}

// ========== PRODUCT MODELS ==========

model Product {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  description     String
  price           Float
  compareAtPrice  Float?
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  designerId      String?
  designer        Designer?     @relation(fields: [designerId], references: [id])
  tags            String[]
  images          ProductImage[]
  stock           Stock?
  discountId      String?
  discount        Discount?     @relation(fields: [discountId], references: [id])
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  rating          Float         @default(0)
  reviewsCount    Int           @default(0)
  reviews         Review[]
  cartItems       CartItem[]
  wishlistItems   Wishlist[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Category {
  id              String        @id @default(cuid())
  name            String        @unique
  slug            String        @unique
  headerImage     String?
  products        Product[]
  order           Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Designer {
  id              String        @id @default(cuid())
  designerId      String        @unique
  fullName        String
  specialty       String
  location        String        @default("Mombasa")
  profileImage    String?
  spotlightHeading String?
  spotlightText   String?
  products        Product[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ProductImage {
  id              String        @id @default(cuid())
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  url             String
  alt             String?
  isMain          Boolean       @default(false)
  order           Int           @default(0)
}

model Review {
  id              String        @id @default(cuid())
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  rating          Int
  comment         String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ========== STOCK MODELS ==========

model Stock {
  id              String        @id @default(cuid())
  productId       String        @unique
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int           @default(100)
  maxStock        Int           @default(100)
  minThreshold    Int           @default(10)
  status          StockStatus   @default(IN_STOCK)
  lastRestocked   DateTime?
  restockHistory  RestockHistory[]
  stockLogs       StockLog[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model RestockHistory {
  id              String        @id @default(cuid())
  stockId         String
  stock           Stock         @relation(fields: [stockId], references: [id])
  quantity        Int
  reason          String
  adminId         String?
  createdAt       DateTime      @default(now())
}

model StockLog {
  id              String        @id @default(cuid())
  stockId         String
  stock           Stock         @relation(fields: [stockId], references: [id])
  previousStock   Int
  newStock        Int
  action          String
  adminId         String?
  createdAt       DateTime      @default(now())
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

// ========== DISCOUNT MODELS ==========

model Discount {
  id              String        @id @default(cuid())
  name            String
  type            DiscountType  @default(PERCENTAGE)
  value           Float
  applyTo         ApplyTo       @default(ALL)
  targetIds       String[]
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean       @default(true)
  products        Product[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum ApplyTo {
  ALL
  CATEGORY
  SELECTED
}

// ========== ORDER MODELS ==========

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  items           OrderItem[]
  subtotal        Float
  discount        Float         @default(0)
  tax             Float
  shippingCost    Float
  total           Float
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  deliveryMethod  DeliveryMethod @default(STANDARD)
  addressId       String
  address         Address       @relation(fields: [addressId], references: [id])
  trackingNumber  String?
  notes           String?
  cancellationReason String?
  refundApproved  Boolean       @default(false)
  pickedUpAt      DateTime?
  autoStageEnabled Boolean      @default(true)
  autoStagePaused Boolean       @default(false)
  autoStageLastUpdate DateTime?
  awaitingRefundAt DateTime?
  refundNotificationSent Boolean @default(false)
  refundNotificationLastSentAt DateTime?
  trackingHistory TrackingEvent[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  productId       String
  productName     String
  productPrice    Float
  quantity        Int
  subtotal        Float
  productImage    String?
}

model TrackingEvent {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  status          OrderStatus
  description     String
  location        String?
  createdAt       DateTime      @default(now())
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  READY_FOR_PICKUP
  DELIVERED
  CANCELLED
  AWAITING_REFUND
  RETURNED
}

enum PaymentMethod {
  MPESA
  CARD
  BANK_TRANSFER
  COD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DeliveryMethod {
  STORE_PICKUP
  SAME_DAY
  STANDARD
}



